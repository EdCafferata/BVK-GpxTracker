default_platform(:ios)

SCHEME       = "OpenBVKTracker"
PROJECT      = "OpenBVKTracker.xcodeproj"
BUNDLE_ID    = "info.cafferata.BvkGpxTracker"
SCREENSHOTS  = "AppStore/Screenshots"

platform :ios do

  # ─── TestFlight ────────────────────────────────────────────────────────────
  desc "Build en upload naar TestFlight"
  lane :beta do
    increment_build_number(xcodeproj: PROJECT)
    build_app(
      project:           PROJECT,
      scheme:            SCHEME,
      configuration:     "Release",
      export_method:     "app-store",
      export_options: {
        provisioningProfiles: {
          BUNDLE_ID => "match AppStore #{BUNDLE_ID}"
        }
      }
    )
    upload_to_testflight(
      skip_waiting_for_build_processing: true
    )
  end

  # ─── App Store release ─────────────────────────────────────────────────────
  desc "Build, upload naar App Store en dien in ter beoordeling"
  lane :release do
    increment_build_number(xcodeproj: PROJECT)
    build_app(
      project:           PROJECT,
      scheme:            SCHEME,
      configuration:     "Release",
      export_method:     "app-store",
      export_options: {
        provisioningProfiles: {
          BUNDLE_ID => "match AppStore #{BUNDLE_ID}"
        }
      }
    )
    upload_to_app_store(
      submit_for_review:            true,
      automatic_release:            false,
      force:                        true,
      skip_screenshots:             false,
      screenshots_path:             SCREENSHOTS,
      metadata_path:                "fastlane/metadata",
      submission_information: {
        add_id_info_uses_idfa: false
      }
    )
  end

  # ─── Alleen screenshots uploaden ───────────────────────────────────────────
  desc "Upload screenshots naar App Store Connect"
  lane :screenshots do
    upload_to_app_store(
      skip_binary_upload: true,
      skip_metadata:      true,
      force:              true,
      screenshots_path:   SCREENSHOTS
    )
  end

  # ─── Alleen metadata uploaden ──────────────────────────────────────────────
  desc "Upload beschrijving en release notes naar App Store Connect"
  lane :metadata do
    upload_to_app_store(
      skip_binary_upload: true,
      skip_screenshots:   true,
      force:              true,
      metadata_path:      "fastlane/metadata"
    )
  end

end
